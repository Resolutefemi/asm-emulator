# Renance Playground Environment Variables
# Copy this to .env for local development

# Tauri Settings
TAURI_DEV_SERVER_URL=http://localhost:5173
TAURI_PRIVATE_KEY=your-private-key-here
TAURI_KEY_PASSWORD=your-password-here

# Build Target (optional)
# TAURI_BUILD_TARGET=x86_64-pc-windows-gnu

# Debug mode
# RUST_BACKTRACE=1
